# Backend .env
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restotraiteur
DB_USER=restotraiteur_dbadmin
DB_PASSWORD=monrestotraiteur_2025

# Configuration développement
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-development-2025
JWT_EXPIRES_IN=7d

# CinetPay Configuration
# ⚠️  Ces credentials ne sont utilisés QU'en mode live (PAYMENT_MODE=live)
# En mode sandbox, le backend simule le paiement sans appeler CinetPay
CINETPAY_API_KEY=sandbox-api-key-12345678
CINETPAY_SITE_ID=sandbox-site-id-87654321
CINETPAY_SECRET_KEY=sandbox-secret-key-abcdefgh
CINETPAY_API_URL=https://api-checkout.cinetpay.com/v2
CINETPAY_NOTIFY_URL=http://localhost:3000/api/payments/webhook/cinetpay
CINETPAY_RETURN_URL=http://localhost:4200/payment-success
CINETPAY_CANCEL_URL=http://localhost:4200/payment-cancel

# ✅ MODE PAIEMENT — choisir UNE seule valeur :
#   sandbox → paiement immédiat simulé, aucun appel CinetPay, pas de vrai argent
#   live    → flow CinetPay réel (à utiliser UNIQUEMENT en production)
PAYMENT_MODE=sandbox

# Autres services
FRONTEND_URL=http://localhost:4200
API_BASE_URL=http://localhost:3000

